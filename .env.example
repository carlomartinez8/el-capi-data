# ── Supabase (same as la-copa-mundo) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API-Football ──
API_FOOTBALL_KEY=your-api-football-key

# ── OpenAI (for ChatGPT enrichment) ──
OPENAI_API_KEY=your-openai-api-key

# ── Paths ──
# Where the Transfermarkt CSVs live (default: ../la-copa-mundo/scripts/pipeline/data)
TRANSFERMARKT_DATA_DIR=../la-copa-mundo/scripts/pipeline/data

# Where the static players.ts lives
STATIC_SQUADS_PATH=../la-copa-mundo/src/data/players.ts
